# Golf Booking App - Environment Variables
# Copy this file to .env and fill in your actual API keys

# ===================================
# GolfCourseAPI.com (FREE)
# ===================================
# Sign up at: https://golfcourseapi.com/
# Provides: Course database, GPS coordinates, ratings
# Cost: FREE
VITE_GOLF_COURSE_API_KEY=your_golfcourseapi_key_here

# ===================================
# GolfNow API (Paid - requires approval)
# ===================================
# Apply at: https://api.gnsvc.com/
# Provides: Real-time tee time booking, availability, payments
# Cost: Contact GolfNow for pricing
VITE_GOLF_NOW_API_KEY=your_golfnow_api_key_here
VITE_GOLF_NOW_BASE_URL=https://api.gnsvc.com/rest

# ===================================
# Optional: Google Maps API
# ===================================
# For enhanced map features (optional)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ===================================
# Firebase Config (for Fluff integration)
# ===================================
VITE_FIREBASE_API_KEY="AIzaSyBhdyQSv15D1DohjCDZMwY5lq-JEurwUKg"
VITE_FIREBASE_AUTH_DOMAIN="theclubhouse-cf31f.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="theclubhouse-cf31f"
VITE_FIREBASE_STORAGE_BUCKET="theclubhouse-cf31f.firebasestorage.app"
